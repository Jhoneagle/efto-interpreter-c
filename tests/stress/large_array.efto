// Test large array operations.

var arr = [];
for (var i = 0; i < 1000; i = i + 1) {
  arr.push(i);
}

print arr.length; // expect: 1000
print arr[0];     // expect: 0
print arr[999];   // expect: 999

// Map over large array.
var doubled = arr.map((x) => x * 2);
print doubled[500]; // expect: 1000

// Filter large array.
var evens = arr.filter((x) => x % 2 == 0);
print evens.length; // expect: 500

// Reduce large array.
var sum = arr.reduce((acc, x) => acc + x, 0);
print sum; // expect: 499500
