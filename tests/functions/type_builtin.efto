// type() builtin function.
print type(nil);           // expect: nil
print type(true);          // expect: bool
print type(false);         // expect: bool
print type(42);            // expect: number
print type(3.14);          // expect: number
print type("hello");       // expect: string
print type([1, 2, 3]);     // expect: array
print type({"a": 1});      // expect: map
print type(type);          // expect: function
fun dummy() {}
print type(dummy);         // expect: function

class Foo {}
print type(Foo);           // expect: class
print type(Foo());         // expect: instance
