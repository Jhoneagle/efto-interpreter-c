// Simple file I/O helpers.
import io;

var tmpFile = "tests/io/_test_tmp.txt";

try {
  // writeFile + readFile.
  io.writeFile(tmpFile, "hello world");
  print io.readFile(tmpFile); // expect: hello world

  // fileExists.
  print io.fileExists(tmpFile); // expect: true
  print io.fileExists("tests/io/_no_such_file.txt"); // expect: false

  // appendFile.
  io.appendFile(tmpFile, "\nsecond line");
  print io.readFile(tmpFile); // expect: hello world
  // expect: second line

  // deleteFile.
  print io.deleteFile(tmpFile); // expect: true
  print io.fileExists(tmpFile); // expect: false

  // deleteFile on non-existent file.
  print io.deleteFile("tests/io/_no_such_file.txt"); // expect: false
} finally {
  // Ensure cleanup even if a test assertion fails.
  if (io.fileExists(tmpFile)) {
    io.deleteFile(tmpFile);
  }
}
