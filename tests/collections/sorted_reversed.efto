// Collections module: sorted and reversed (non-mutating).
import collections;

// sorted returns a new sorted array.
var arr = [3, 1, 4, 1, 5];
var s = collections.sorted(arr);
print s; // expect: [1, 1, 3, 4, 5]
// Original is unchanged.
print arr; // expect: [3, 1, 4, 1, 5]

// sorted with strings.
print collections.sorted(["banana", "apple", "cherry"]); // expect: [apple, banana, cherry]

// sorted empty array.
print collections.sorted([]); // expect: []

// reversed returns a new reversed array.
var r = collections.reversed([1, 2, 3]);
print r; // expect: [3, 2, 1]
// Original is unchanged.
var orig = [1, 2, 3];
collections.reversed(orig);
print orig; // expect: [1, 2, 3]

// reversed empty array.
print collections.reversed([]); // expect: []

// reversed single element.
print collections.reversed([42]); // expect: [42]
