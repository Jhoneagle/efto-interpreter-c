// Spread in array literals.
var a = [1, 2, 3];
var b = [0, ...a, 4];
print b.length;  // expect: 5
print b[0];      // expect: 0
print b[1];      // expect: 1
print b[2];      // expect: 2
print b[3];      // expect: 3
print b[4];      // expect: 4

// Multiple spreads.
var x = [1, 2];
var y = [3, 4];
var z = [...x, ...y];
print z.length;  // expect: 4
print z[0];      // expect: 1
print z[3];      // expect: 4

// Spread empty array.
var empty = [];
var c = [1, ...empty, 2];
print c.length;  // expect: 2
print c[0];      // expect: 1
print c[1];      // expect: 2

// Spread only.
var d = [...a];
print d.length;  // expect: 3
print d[0];      // expect: 1

// Array literal without spread still works.
var e = [10, 20, 30];
print e.length;  // expect: 3
print e[1];      // expect: 20
