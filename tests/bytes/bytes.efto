// bytes: immutable byte-buffer type — construction, access, methods, iteration.

// Construct from an array of ints.
var b = Bytes([104, 105, 33]); // "hi!"
print typeof b;   // expect: bytes
print b.length;   // expect: 3
print b[0];       // expect: 104
print b[2];       // expect: 33
print b;          // expect: bytes(len=3)

// Construct from a string (UTF-8 bytes).
var s = Bytes("ABC");
print s.length;   // expect: 3
print s[0];       // expect: 65
print s[1];       // expect: 66

// Empty bytes.
var e = Bytes();
print e.length;   // expect: 0

// toArray.
var arr = s.toArray();
print arr;        // expect: [65, 66, 67]

// hex and bytesFromHex round-trip.
print b.hex();                       // expect: 686921
var h = bytesFromHex("686921");
print h == b;                        // expect: true
print bytesFromHex("").length;       // expect: 0

// indexOf.
print b.indexOf(105);  // expect: 1
print b.indexOf(200);  // expect: -1

// slice (with negative indices).
var sl = b.slice(0, 2);
print sl.length;   // expect: 2
print sl[0];       // expect: 104
print b.slice(-1, 3)[0]; // expect: 33

// Iteration yields ints.
var total = 0;
for (var byteVal in b) { total = total + byteVal; }
print total; // expect: 242

// Content equality (bytes are not interned).
print Bytes([1, 2, 3]) == Bytes([1, 2, 3]); // expect: true
print Bytes([1, 2, 3]) == Bytes([1, 2, 4]); // expect: false

// Usable as a map key by content.
var m = {};
m[Bytes([1, 2])] = "a";
m[Bytes([3, 4])] = "b";
print m[Bytes([1, 2])]; // expect: a
print m[Bytes([3, 4])]; // expect: b

// ...and as a set element.
var st = Set();
st.add(Bytes([9]));
st.add(Bytes([9]));
print st.size; // expect: 1
