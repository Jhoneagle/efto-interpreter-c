import math;

// Integer arithmetic.
print 5 / 2;    // expect: 2
print 7 % 3;    // expect: 1
print -7 / 2;   // expect: -3
print -7 % 3;   // expect: -1

// Mixed arithmetic promotes to double.
print 5 + 1.0;  // expect: 6
print 5 / 2.0;  // expect: 2.5
print 5 * 1.0;  // expect: 5
print 5 - 1.0;  // expect: 4

// No backward promotion.
print 6.0 / 2.0;  // expect: 3

// Type checking.
print typeof 5;     // expect: int
print typeof 5.0;   // expect: double
print typeof (5 + 3);   // expect: int
print typeof (5 + 3.0); // expect: double

// Cross-type equality.
print 1 == 1.0;  // expect: true
print 1 == 1.5;  // expect: false
print 0 == 0.0;  // expect: true

// Comparisons.
print 5 > 3.0;   // expect: true
print 3.0 < 5;   // expect: true
print 5 > 5.0;   // expect: false

// Bitwise requires int.
print 3 & 1;     // expect: 1
print 3 | 4;     // expect: 7
print ~0;         // expect: -1
print 1 << 32;   // expect: 4294967296

// Conversion.
print toInt(3.14);    // expect: 3
print toInt("42");    // expect: 42
print toDouble(5);    // expect: 5
print toDouble("3.14"); // expect: 3.14

// Math functions.
print typeof math.floor(3.7);  // expect: int
print math.floor(3.7);         // expect: 3
print typeof math.ceil(2.1);   // expect: int
print math.ceil(2.1);          // expect: 3
print typeof math.round(2.5);  // expect: int
print math.round(2.5);         // expect: 3
print typeof math.sqrt(4);     // expect: double
print math.sign(-5);           // expect: -1
print math.sign(0);            // expect: 0
print math.sign(3.14);         // expect: 1

// abs preserves type.
print typeof math.abs(-5);     // expect: int
print typeof math.abs(-5.0);   // expect: double
print math.abs(-5);            // expect: 5
print math.abs(-5.0);          // expect: 5

// Negate preserves type.
print typeof -5;     // expect: int
print typeof -5.0;   // expect: double

// Properties return int.
print typeof [1,2,3].length;   // expect: int
print typeof "hello".length;   // expect: int
