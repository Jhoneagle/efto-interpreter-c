// Basic switch with matching case.
var x = 2;
switch (x) {
  case 1: print "one";
  case 2: print "two"; // expect: two
  case 3: print "three";
}

// Switch with block body.
var y = 1;
switch (y) {
  case 1: {
    var msg = "block one";
    print msg; // expect: block one
  }
  case 2: print "two";
}

// Switch with default.
var z = 99;
switch (z) {
  case 1: print "one";
  case 2: print "two";
  default: print "default"; // expect: default
}

// Switch matching first case.
switch (1) {
  case 1: print "first"; // expect: first
  case 2: print "second";
  default: print "fallback";
}

// Switch with string cases.
var name = "bob";
switch (name) {
  case "alice": print "alice";
  case "bob": print "bob"; // expect: bob
  case "charlie": print "charlie";
}

// Switch with no matching case and no default.
switch (42) {
  case 1: print "one";
  case 2: print "two";
}

// Switch with expression as switch value.
switch (1 + 1) {
  case 2: print "math works"; // expect: math works
  default: print "broken";
}

// Switch with default only.
switch (5) {
  default: print "only default"; // expect: only default
}

// Switch with block in default.
switch (0) {
  case 1: print "one";
  default: {
    var a = "default";
    var b = " block";
    print a + b; // expect: default block
  }
}
