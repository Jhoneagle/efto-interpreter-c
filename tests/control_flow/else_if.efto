// Else-if chaining.
var x = 10;

if (x < 5) {
  print "small";
} else if (x < 15) {
  print "medium"; // expect: medium
} else {
  print "large";
}

// Multiple else-if branches.
var grade = 75;
if (grade >= 90) {
  print "A";
} else if (grade >= 80) {
  print "B";
} else if (grade >= 70) {
  print "C"; // expect: C
} else if (grade >= 60) {
  print "D";
} else {
  print "F";
}

// Else-if with no final else.
var y = 3;
if (y == 1) {
  print "one";
} else if (y == 2) {
  print "two";
} else if (y == 3) {
  print "three"; // expect: three
}
