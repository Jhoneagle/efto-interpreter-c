// If/else statements.
if (true) print "yes";   // expect: yes
if (false) print "no";

if (true) {
  print "then"; // expect: then
} else {
  print "else";
}

if (false) {
  print "then";
} else {
  print "else"; // expect: else
}

if (nil) {
  print "bad";
} else {
  print "nil is falsey"; // expect: nil is falsey
}

if (0) print "zero is truthy"; // expect: zero is truthy
